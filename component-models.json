    {
      "title": "Section",
      "id": "section",
      "components": [
        {
          "title": "Section",
          "id": "section",
          "plugins": {
            "xwalk": {
              "page": {
                "resourceType": "core/franklin/components/section/v1/section",
                "template": {}
              }
            }
          },
          "model": {
            "id": "section",
            "fields": [
              {
                "component": "select",
                "name": "style",
                "label": "Style",
                "valueType": "string",
                "options": [
                  { "name": "Default", "value": "" },
                  { "name": "Shaded", "value": "shaded" },
                  { "name": "Dark", "value": "dark" },
                  { "name": "Brand", "value": "brand" },
                  { "name": "Teal", "value": "teal" }
                ]
              },
              {
                "component": "select",
                "name": "grid",
                "label": "Grid Columns",
                "valueType": "string",
                "options": [
                  { "name": "None", "value": "" },
                  { "name": "2 Columns", "value": "2" },
                  { "name": "3 Columns", "value": "3" },
                  { "name": "4 Columns", "value": "4" },
                  { "name": "5 Columns", "value": "5" },
                  { "name": "6 Columns", "value": "6" }
                ]
              },
              {
                "component": "select",
                "name": "spacing",
                "label": "Spacing",
                "valueType": "string",
                "options": [
                  { "name": "Default", "value": "" },
                  { "name": "Extra Small", "value": "xs" },
                  { "name": "Small", "value": "s" },
                  { "name": "Medium", "value": "m" },
                  { "name": "Large", "value": "l" },
                  { "name": "Extra Large", "value": "xl" },
                  { "name": "2XL", "value": "xxl" }
                ]
              }
            ]
          }
        }
